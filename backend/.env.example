# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/salesmind

# Redis
REDIS_URL=redis://localhost:6379/0

# AI APIs (Required for AI features)
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# Free AI Provider Options
AI_PROVIDER=gemini  # Options: gemini, groq, kimi
GEMINI_API_KEY=your-gemini-api-key  # Free 1500 requests/day
GROQ_API_KEY=your-groq-api-key  # Free 20 requests/min
KIMI_API_KEY=your-kimi-api-key  # 免费额度15元

# Security
SECRET_KEY=your-secret-key-here-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
